    /// @dev MiMC7 permutation: x = (x + c_i + k)^7 over bn254 scalar field
    function _mimc7(uint256 x, uint256 k) private pure returns (uint256) {
        for (uint256 i = 0; i < 91; i++) {
            uint256 t = addmod(addmod(x, _C(i), R), k, R);
            x = mulmod(mulmod(mulmod(t, t, R), mulmod(t, t, R), R), mulmod(mulmod(t, t, R), t, R), R);
        }
        return addmod(x, k, R);
    }

    /// @dev Hash two field elements (seqNum, dataEl). Matches circomlib MiMC sponge for 2 inputs.
    /// Both inputs must be < R.
    function hash(uint256 x, uint256 y) internal pure returns (uint256) {
        uint256 h = _mimc7(0, x);
        return _mimc7(addmod(h, y, R), h);
    }

    /// @dev Hash bytes: dataHash = MiMC(seqNum, keccak256(data) % R).
    /// Converts arbitrary data to a field element via keccak256, then MiMC hashes with seqNum.
    /// Circuit never computes keccak256; signers sign over this dataHash.
    function hashBytes(uint256 seqNum, bytes memory data) internal pure returns (uint256) {
        uint256 dataEl = uint256(keccak256(data)) % R;
        return hash(seqNum, dataEl);
    }
